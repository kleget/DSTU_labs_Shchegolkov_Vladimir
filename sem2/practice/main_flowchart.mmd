flowchart TD
  A([Начало]) --> B["Ввод f(x), a, b, ε"]
  B --> C{"Валидация ввода"}
  C -- "Ошибки" --> D["Печать списка ошибок"]
  D --> Z([Конец])

  C -- "OK" --> E["Преобразование a,b,ε в числа"]
  E --> F["Построение f(x) через sympy"]
  F --> G["fa=f(a), fb=f(b)"]
  G --> H{"fa * fb > 0?"}
  H -- "Да" --> I["Сообщение: условия не выполнены"]
  I --> Z
  H -- "Нет" --> J["Инициализация: a,b, iteration=0, max_iterations"]

  J --> K["Печать заголовка таблицы"]
  K --> L["iteration+=1; c=(a+b)/2; fc=f(c)"]
  L --> M["Печать строки итерации"]
  M --> N{"abs(b-a) <= ε?"}
  N -- "Да" --> O["Выход из цикла"]
  N -- "Нет" --> P{"f(a) * fc > 0?"}
  P -- "Да" --> Q["a = c"]
  P -- "Нет" --> R["b = c"]
  Q --> L
  R --> L

  O --> S["root=(a+b)/2; печать результата"]
  S --> T{"iteration == max_iterations?"}
  T -- "Да" --> U["Предупреждение о max_iterations"]
  T -- "Нет" --> V["Пропуск"]
  U --> W{"Построить график?"}
  V --> W
  W -- "Да" --> X["draw_function_plot"]
  W -- "Нет" --> Z
  X --> Z
